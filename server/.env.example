# Copy this file to ".env" and fill in real values.
# .env is gitignored — never commit real secrets.
# In production (Render), set these under the service's "Environment" tab.

# ─── Database (MongoDB Atlas) ───
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Render sets PORT automatically; this is only used for local dev.
PORT=4000

# ─── Auth ───
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Bootstrap super-admin (created on first start if none exists)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@smartfactory.local
SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword123!

# ─── Idle-escalation timers (seconds). Production: 300 / 1800 (5 min / 30 min) ───
ESCALATE_SUPERVISOR_SEC=300
ESCALATE_PLANTHEAD_SEC=1800

# ─── Optional SMTP (emails credentials/alerts; otherwise logged to console) ───
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=SmartFactory <no-reply@yourco.com>
# APP_URL=https://your-frontend.vercel.app
